<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:MeetingTranslator.Models"
                    xmlns:converters="clr-namespace:MeetingTranslator.Converters">

    <!-- ═══ CONVERSORES ═══ -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <converters:StringToVisibilityConverter x:Key="StringToVis"/>
    <converters:Base64ToImageConverter x:Key="Base64ToImg"/>
    <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>

    <!-- ═══ ANIMAÇÕES ═══ -->

    <!-- Animação de pulso para o indicador "Analisando..." -->
    <Storyboard x:Key="PulseAnimation"
                RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="1.0"
                         To="0.3"
                         Duration="0:0:0.8"
                         AutoReverse="True"/>
    </Storyboard>

    <!-- Animação de Slide para os painéis -->
    <Storyboard x:Key="SlideDownAnimation">
        <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                         From="0" To="500" Duration="0:0:0.25">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <Storyboard x:Key="SlideUpAnimation">
        <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                         From="500" To="0" Duration="0:0:0.2">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseIn"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <Storyboard x:Key="SubtitleFadeIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.3"/>
    </Storyboard>

    <!-- ═══ PALETA DE CORES ═══ -->

    <!-- Fundo semi-transparente escuro -->
    <SolidColorBrush x:Key="BarBg"      Color="#CC1A1A2E"/>
    <SolidColorBrush x:Key="BarBgSolid" Color="#FF1A1A2E"/>

    <!-- Cores de destaque -->
    <SolidColorBrush x:Key="AccentBlue"  Color="#FF4A9EFF"/>
    <SolidColorBrush x:Key="AccentGreen" Color="#FF4AFF8A"/>
    <SolidColorBrush x:Key="AccentGold"  Color="#FFFFAA00"/>

    <!-- Texto -->
    <SolidColorBrush x:Key="TextPrimary"   Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#99FFFFFF"/>

    <!-- Interação -->
    <SolidColorBrush x:Key="ButtonHover" Color="#33FFFFFF"/>

    <!-- Bolhas do histórico -->
    <SolidColorBrush x:Key="ChatAssistantBubble" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ChatUserBubble"      Color="#FF4A9EFF"/>
    <SolidColorBrush x:Key="ChatAiBubble"        Color="#33FF00CC"/>

    <!-- ═══ ESTILOS DE CONTROLES ═══ -->

    <!-- Botão minimalista da barra -->
    <Style x:Key="BarButton" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="Foreground"       Value="{StaticResource TextSecondary}"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Padding"          Value="8,4"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{StaticResource ButtonHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TabControl escuro -->
    <Style x:Key="DarkTabControl" TargetType="TabControl">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="0"/>
    </Style>

    <!-- TabItem escuro -->
    <Style x:Key="DarkTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="bd"
                            Padding="14,8"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2"
                            Cursor="Hand">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush"
                                    Value="{StaticResource AccentBlue}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource TextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{StaticResource ButtonHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBoxItem escuro — contraste forte para itens da lista -->
    <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground"         Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily"         Value="Segoe UI"/>
        <Setter Property="FontSize"           Value="12"/>
        <Setter Property="Padding"            Value="10,6"/>
        <Setter Property="Background"         Value="Transparent"/>
        <Setter Property="BorderThickness"    Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource ButtonHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource AccentBlue}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource TextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox escuro -->
    <Style x:Key="DarkComboBox" TargetType="ComboBox">
        <Setter Property="Background"             Value="#22FFFFFF"/>
        <Setter Property="Foreground"             Value="{StaticResource TextPrimary}"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush"            Value="#33FFFFFF"/>
        <Setter Property="BorderThickness"        Value="1"/>
        <Setter Property="FontSize"               Value="11"/>
        <Setter Property="FontFamily"             Value="Segoe UI"/>
        <Setter Property="Padding"                Value="6,4"/>
        <Setter Property="MaxWidth"               Value="380"/>
        <Setter Property="HorizontalAlignment"    Value="Left"/>
        <Setter Property="Margin"                 Value="0,4,0,0"/>
        <Setter Property="ItemContainerStyle"     Value="{StaticResource DarkComboBoxItem}"/>
    </Style>

    <!-- RadioButton estilo pílula -->
    <Style x:Key="PillRadio" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Margin"     Value="0,0,6,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd"
                            Background="#11FFFFFF"
                            CornerRadius="12"
                            Padding="14,6"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background"   Value="#334A9EFF"/>
                            <Setter TargetName="bd" Property="BorderBrush"  Value="{StaticResource AccentBlue}"/>
                            <Setter Property="Foreground"                   Value="{StaticResource TextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"   Value="#22FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBox escuro -->
    <Style x:Key="DarkTextBox" TargetType="TextBox">
        <Setter Property="Background"          Value="#22FFFFFF"/>
        <Setter Property="Foreground"          Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush"         Value="#33FFFFFF"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="FontSize"            Value="11"/>
        <Setter Property="FontFamily"          Value="Segoe UI"/>
        <Setter Property="Padding"             Value="6,4"/>
        <Setter Property="MinWidth"            Value="260"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin"              Value="0,3,0,0"/>
        <Setter Property="CaretBrush"          Value="White"/>
    </Style>

    <!-- ═══ DATA TEMPLATES ═══ -->

    <!-- Template de item do histórico como bolhas de chat -->
    <DataTemplate x:Key="HistoryItemTemplate">
        <Grid Margin="12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="Bubble"
                    Grid.Column="0"
                    Background="{StaticResource ChatAssistantBubble}"
                    CornerRadius="16"
                    Padding="12,8"
                    MaxWidth="420"
                    HorizontalAlignment="Left">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SpeakerLabel"
                                   Text="Outro:"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,4"/>
                        <Button Grid.Column="1"
                                Style="{StaticResource BarButton}"
                                Height="20"
                                Padding="4,0"
                                Margin="8,0,0,0"
                                ToolTip="Copiar"
                                Command="{Binding DataContext.CopyBubbleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <TextBlock Text="📋" FontSize="10"/>
                        </Button>
                    </Grid>
                    
                    
                    <!-- Imagem Anexada -->
                    <Border CornerRadius="8" Margin="0,4,0,4" ClipToBounds="True" MaxHeight="200" HorizontalAlignment="Left"
                            Visibility="{Binding AttachedImageBase64, Converter={StaticResource StringToVis}}">
                        <Image Source="{Binding AttachedImageBase64, Converter={StaticResource Base64ToImg}}" Stretch="Uniform" StretchDirection="DownOnly"/>
                    </Border>
                    
                    <TextBlock Text="{Binding TranslatedText}"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="13"
                               FontFamily="Segoe UI"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding OriginalText}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               Visibility="{Binding OriginalText, Converter={StaticResource StringToVis}}"/>
                    <TextBlock Text="{Binding TimeLabel}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="10"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Speaker}" Value="You">
                <Setter TargetName="Bubble" Property="Grid.Column"          Value="1"/>
                <Setter TargetName="Bubble" Property="HorizontalAlignment"  Value="Right"/>
                <Setter TargetName="Bubble" Property="Background"           Value="{StaticResource ChatUserBubble}"/>
                <Setter TargetName="SpeakerLabel" Property="Text"           Value="Você:"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Speaker}" Value="Them">
                <Setter TargetName="Bubble" Property="Grid.Column"          Value="0"/>
                <Setter TargetName="Bubble" Property="HorizontalAlignment"  Value="Left"/>
                <Setter TargetName="Bubble" Property="Background"           Value="{StaticResource ChatAssistantBubble}"/>
                <Setter TargetName="SpeakerLabel" Property="Text"           Value="Outro:"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Speaker}" Value="AI">
                <Setter TargetName="Bubble" Property="Grid.Column"          Value="0"/>
                <Setter TargetName="Bubble" Property="HorizontalAlignment"  Value="Stretch"/>
                <Setter TargetName="Bubble" Property="Background"           Value="{StaticResource ChatAiBubble}"/>
                <Setter TargetName="SpeakerLabel" Property="Text"           Value="✨ Gemini IA:"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>
