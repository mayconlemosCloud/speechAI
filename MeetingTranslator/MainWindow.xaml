<Window x:Class="MeetingTranslator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeetingTranslator"
        xmlns:models="clr-namespace:MeetingTranslator.Models"
        mc:Ignorable="d"
        Title="Meeting Translator"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        Width="700"
        SizeToContent="Height"
        Left="100"
        Top="10"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        PreviewKeyDown="Window_PreviewKeyDown">

        <Window.Resources>
                <ResourceDictionary>
                        <ResourceDictionary.MergedDictionaries>
                                <ResourceDictionary Source="Resources/Styles.xaml"/>
                        </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
        </Window.Resources>

        <Border CornerRadius="10"
                Background="{StaticResource BarBg}"
                BorderBrush="#33FFFFFF"
                BorderThickness="1">
                <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                </Border.Effect>
                <Grid>
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Subtitle bar -->
                                <RowDefinition Height="Auto"/>
                                <!-- Settings panel -->
                                <RowDefinition Height="Auto"/>
                                <!-- History drawer -->
                        </Grid.RowDefinitions>

                        <!-- ═══ ROW 0: SUBTITLE BAR ═══ -->
                        <Grid Grid.Row="0"
                              MinHeight="48">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Status dot -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Subtitle text -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Buttons -->
                                </Grid.ColumnDefinitions>

                                <!-- Status indicator -->
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="12,0,8,0"
                                            VerticalAlignment="Center">
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 x:Name="StatusDot">
                                                <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                                <Setter Property="Fill"
                                                                        Value="#FF555555"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsConnected}"
                                                                                     Value="True">
                                                                                <Setter Property="Fill"
                                                                                        Value="#FF00CC66"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsAnalyzing}"
                                                                                     Value="True">
                                                                                <Setter Property="Fill"
                                                                                        Value="#FFFFAA00"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Ellipse.Style>
                                        </Ellipse>
                                        <!-- Dot de status do intérprete (dourado, visível quando conectado) -->
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 Fill="{StaticResource AccentGold}"
                                                 Margin="4,0,0,0"
                                                 VerticalAlignment="Center"
                                                 ToolTip="{Binding SpeakStatusText}"
                                                 Visibility="{Binding IsSpeakConnected, Converter={StaticResource BoolToVis}}"/>
                                        <!-- Dot pulsante dourado: indica que o intérprete está falando -->
                                        <Ellipse x:Name="SpeakingDot"
                                                 Width="8"
                                                 Height="8"
                                                 Fill="{StaticResource AccentGold}"
                                                 Margin="4,0,0,0"
                                                 VerticalAlignment="Center"
                                                 ToolTip="Intérprete falando"
                                                 Visibility="{Binding IsSpeaking, Converter={StaticResource BoolToVis}}"/>
                                        <!-- Analyzing label (pulsing) -->
                                        <TextBlock x:Name="AnalyzingLabel"
                                                   Text="🔄 Analisando..."
                                                   Foreground="#FFFFAA00"
                                                   FontSize="10"
                                                   FontFamily="Segoe UI"
                                                   FontWeight="SemiBold"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="10"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe UI"/>
                                </StackPanel>

                                <!-- Subtitle text -->
                                <TextBlock x:Name="SubtitleBlock"
                                           Grid.Column="1"
                                           Text="{Binding SubtitleText}"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="16"
                                           FontFamily="Segoe UI"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Padding="4,10"
                                           TextAlignment="Left"/>

                                <!-- Action buttons -->
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            Margin="4,0,8,0"
                                            VerticalAlignment="Center">
                                        <!-- History toggle -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="▼"
                                                Click="ToggleHistory_Click"
                                                ToolTip="Histórico"
                                                FontSize="10"
                                                Padding="6,4"/>

                                        <!-- Capture Screen -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="📸"
                                                Click="CaptureScreen_Click"
                                                ToolTip="Capturar Tela (IA)"
                                                FontSize="12"/>

                                        <!-- Mute -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="{Binding MuteIcon}"
                                                Click="ToggleMute_Click"
                                                ToolTip="Mute/Unmute"/>

                                        <!-- Speak (Intérprete Ativo PT→EN) -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="🗣️"
                                                Click="ToggleSpeak_Click"
                                                ToolTip="{Binding SpeakButtonTooltip}"
                                                Visibility="{Binding IsSpeakFeatureEnabled, Converter={StaticResource BoolToVis}}"
                                                FontSize="14"/>

                                        <!-- Connect/Disconnect -->
                                        <Button Style="{StaticResource BarButton}"
                                                Click="ToggleConnect_Click"
                                                ToolTip="{Binding ConnectButtonText}">
                                                <Button.Content>
                                                        <TextBlock FontSize="14">
                                                                <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                                <Setter Property="Text"
                                                                                        Value="⚡"/>
                                                                                <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsConnected}"
                                                                                                     Value="True">
                                                                                                <Setter Property="Text"
                                                                                                        Value="⏹"/>
                                                                                        </DataTrigger>
                                                                                </Style.Triggers>
                                                                        </Style>
                                                                </TextBlock.Style>
                                                        </TextBlock>
                                                </Button.Content>
                                        </Button>

                                        <!-- Settings -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="⚙"
                                                Click="ToggleSettings_Click"
                                                ToolTip="Configurações"/>

                                        <!-- Close -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="✕"
                                                Click="Close_Click"
                                                ToolTip="Fechar"
                                                FontSize="12"/>
                                </StackPanel>
                        </Grid>

                        <!-- ═══ ROW 1: SETTINGS PANEL (Tabs) ═══ -->
                        <Border x:Name="SettingsPanel"
                                Grid.Row="1"
                                Background="{StaticResource BarBgSolid}"
                                Visibility="Visible"
                                MaxHeight="0"
                                ClipToBounds="True"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="0,1,0,0">
                                <TabControl Style="{StaticResource DarkTabControl}" SelectedIndex="{Binding SelectedSettingsTab}">

                                        <!-- ── TAB: ENTRADA ── -->
                                        <TabItem Header="Entrada"
                                                 Style="{StaticResource DarkTabItem}">
                                                <StackPanel Margin="14,12">
                                                        <!-- Modo -->
                                                        <TextBlock Text="Modo"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="12"
                                                                   FontFamily="Segoe UI"/>
                                                        <ComboBox SelectedValue="{Binding SelectedMode}"
                                                                  SelectedValuePath="Tag">
                                                                <ComboBoxItem Content="🎙️ Voz"
                                                                              Tag="{x:Static models:TranslationMode.Voice}"/>
                                                                <ComboBoxItem Content="📝 Transcrição"
                                                                              Tag="{x:Static models:TranslationMode.Transcription}"/>
                                                        </ComboBox>
                                                        <TextBlock Text="{Binding ModeDescription}"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="10"
                                                                   FontFamily="Segoe UI"
                                                                   FontStyle="Italic"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,0,0,14"/>

                                                        <!-- INPUT: único seletor com todos dispositivos (mic + sistema) -->
                                                        <TextBlock Text="INPUT"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="12"
                                                                   FontFamily="Segoe UI"/>
                                                        <ComboBox ItemsSource="{Binding AllInputDevices}"
                                                                  SelectedItem="{Binding SelectedInputDevice}"/>

                                                        <Button Style="{StaticResource BarButton}"
                                                                Content="🔄 Atualizar dispositivos"
                                                                Click="RefreshDevices_Click"
                                                                HorizontalAlignment="Left"
                                                                Foreground="{StaticResource AccentBlue}"
                                                                FontSize="11"/>

                                                        <!-- Azure Voz: filtro, lista e prévia -->
                                                        <TextBlock Text="Voz (Azure)"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="12"
                                                                   FontFamily="Segoe UI"
                                                                   Margin="0,10,0,0"/>
                                                        <TextBox Style="{StaticResource DarkTextBox}"
                                                                 Text="{Binding AzureVoiceFilter, UpdateSourceTrigger=PropertyChanged}"
                                                                 MinWidth="220"
                                                                 Width="280"/>
                                                        <StackPanel Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                                <ComboBox ItemsSource="{Binding AzureVoicesView}"
                                                                          SelectedValue="{Binding AzureSpeechVoice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          SelectedValuePath="ShortName"
                                                                          DisplayMemberPath="DisplayName"/>
                                                                <Button Style="{StaticResource BarButton}"
                                                                        Content="▶️"
                                                                        Click="PreviewAzureVoice_Click"
                                                                        ToolTip="Prévia"
                                                                        FontSize="12"
                                                                        Margin="6,0,0,0"/>
                                                                <TextBlock Text="Carregando..."
                                                                           Foreground="{StaticResource TextSecondary}"
                                                                           FontSize="10"
                                                                           Margin="8,2,0,0"
                                                                           Visibility="{Binding IsAzureBusy, Converter={StaticResource BoolToVis}}"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding AzureSpeechVoice}"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="10"
                                                                   Margin="0,2,0,0"/>
                                                </StackPanel>
                                        </TabItem>

                                        <!-- ── TAB: SAÍDA ── -->
                                        <TabItem Header="Saída"
                                                 Style="{StaticResource DarkTabItem}">
                                                <StackPanel Margin="14,12">
                                                        <!-- Habilitar -->
                                                        <CheckBox IsChecked="{Binding IsSpeakFeatureEnabled}"
                                                                  Margin="0,0,0,10">
                                                                <TextBlock Text="Habilitar Intérprete (PT→EN)"
                                                                           Foreground="{StaticResource TextPrimary}"
                                                                           FontSize="12"
                                                                           FontFamily="Segoe UI"
                                                                           FontWeight="SemiBold"/>
                                                        </CheckBox>

                                                        <StackPanel Visibility="{Binding IsSpeakFeatureEnabled, Converter={StaticResource BoolToVis}}">
                                                                <!-- Mic do intérprete -->
                                                                <Grid Margin="0,0,0,8">
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="🎤"
                                                                                   FontSize="14"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="0,0,8,0"/>
                                                                        <StackPanel Grid.Column="1">
                                                                                <TextBlock Text="Microfone (PT-BR)"
                                                                                           Foreground="{StaticResource TextPrimary}"
                                                                                           FontSize="12"
                                                                                           FontFamily="Segoe UI"/>
                                                                                <ComboBox ItemsSource="{Binding MicDevices}"
                                                                                          SelectedItem="{Binding SelectedSpeakMicDevice}"/>
                                                                        </StackPanel>
                                                                </Grid>

                                                                <!-- Saída do intérprete -->
                                                                <Grid Margin="0,0,0,8">
                                                                        <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="🔈"
                                                                                   FontSize="14"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="0,0,8,0"/>
                                                                        <StackPanel Grid.Column="1">
                                                                                <TextBlock Text="Saída de áudio (EN)"
                                                                                           Foreground="{StaticResource TextPrimary}"
                                                                                           FontSize="12"
                                                                                           FontFamily="Segoe UI"/>
                                                                                <ComboBox ItemsSource="{Binding SpeakOutputDevices}"
                                                                                          SelectedItem="{Binding SelectedSpeakOutputDevice}"/>
                                                                        </StackPanel>
                                                                </Grid>

                                                                <!-- Botão conectar -->
                                                                <Button Style="{StaticResource BarButton}"
                                                                        Click="ToggleSpeak_Click"
                                                                        HorizontalAlignment="Left"
                                                                        Margin="0,4,0,0"
                                                                        FontSize="11">
                                                                        <Button.Content>
                                                                                <TextBlock>
                                                                                        <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                        <Setter Property="Text"
                                                                                                                Value="🗣️ Iniciar Intérprete"/>
                                                                                                        <Setter Property="Foreground"
                                                                                                                Value="{StaticResource AccentGold}"/>
                                                                                                        <Style.Triggers>
                                                                                                                <DataTrigger Binding="{Binding IsSpeakConnected}"
                                                                                                                             Value="True">
                                                                                                                        <Setter Property="Text"
                                                                                                                                Value="⏹ Parar Intérprete"/>
                                                                                                                        <Setter Property="Foreground"
                                                                                                                                Value="#FFFF6B6B"/>
                                                                                                                </DataTrigger>
                                                                                                        </Style.Triggers>
                                                                                                </Style>
                                                                                        </TextBlock.Style>
                                                                                </TextBlock>
                                                                        </Button.Content>
                                                                </Button>

                                                                <!-- Status -->
                                                                <TextBlock Text="{Binding SpeakStatusText}"
                                                                           Foreground="{StaticResource AccentGold}"
                                                                           FontSize="10"
                                                                           FontFamily="Segoe UI"
                                                                           Margin="0,4,0,0"/>

                                                                <!-- Warning -->
                                                                <TextBlock Foreground="#99FFAA00"
                                                                           FontSize="9"
                                                                           FontFamily="Segoe UI"
                                                                           FontStyle="Italic"
                                                                           Margin="0,6,0,0"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding SpeakDeviceWarning}"
                                                                           Visibility="{Binding HasSpeakDeviceWarning, Converter={StaticResource BoolToVis}}"/>
                                                        </StackPanel>
                                                </StackPanel>
                                        </TabItem>

                                        <!-- (Análise de IA Tab Removida: Migrada para o Chat Drawer) -->
                                </TabControl>
                        </Border>

                        <!-- ═══ ROW 2: HISTORY / CHAT DRAWER ═══ -->
                        <Border x:Name="HistoryPanel"
                                Grid.Row="2"
                                Background="{StaticResource BarBgSolid}"
                                Visibility="Visible"
                                MaxHeight="0"
                                ClipToBounds="True"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="0,1,0,0">
                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/> <!-- Input Area -->
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Grid Grid.Row="0"
                                              Margin="14,8,14,4">
                                                <TextBlock Foreground="{StaticResource AccentBlue}"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           FontFamily="Segoe UI"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="HISTÓRICO ({0})">
                                                            <Binding Path="History.Count"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <!-- Chips mágicos do Gemini -->
                                                    <Button Style="{StaticResource BarButton}"
                                                            Content="✨ Resumir"
                                                            Click="AnalyzeMeeting_Click"
                                                            ToolTip="Pede para a IA resumir a conversa atual"
                                                            Foreground="{StaticResource AccentGold}"
                                                            FontSize="11" Margin="0,0,8,0"/>
                                                    <Button Style="{StaticResource BarButton}"
                                                            Content="🗑 Limpar"
                                                            Click="ClearHistory_Click"
                                                            Margin="0,0,8,0"/>
                                                    <Button Style="{StaticResource BarButton}"
                                                            Content="▲ Esconder"
                                                            Click="ToggleHistory_Click"/>
                                                </StackPanel>
                                        </Grid>

                                        <!-- Conversation list -->
                                        <ListBox Grid.Row="1"
                                                 ItemsSource="{Binding History}"
                                                 ItemTemplate="{StaticResource HistoryItemTemplate}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 x:Name="HistoryList"
                                                 VirtualizingPanel.ScrollUnit="Pixel">
                                                <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                                <Setter Property="HorizontalContentAlignment"
                                                                        Value="Stretch"/>
                                                                <Setter Property="Padding"
                                                                        Value="0"/>
                                                                <Setter Property="Margin"
                                                                        Value="0"/>
                                                                <Setter Property="Background"
                                                                        Value="Transparent"/>
                                                                <Setter Property="Template">
                                                                        <Setter.Value>
                                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                                        <ContentPresenter/>
                                                                                </ControlTemplate>
                                                                        </Setter.Value>
                                                                </Setter>
                                                        </Style>
                                                </ListBox.ItemContainerStyle>
                                        </ListBox>

                                        <!-- Empty state -->
                                        <TextBlock Grid.Row="1"
                                                   Text="Nenhuma conversa ainda..."
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,20"
                                                   FontFamily="Segoe UI"
                                                   FontStyle="Italic">
                                                <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility"
                                                                        Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding History.Count}"
                                                                                     Value="0">
                                                                                <Setter Property="Visibility"
                                                                                        Value="Visible"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Typing indicator -->
                                        <TextBlock Grid.Row="2"
                                                   Text="Traduzindo..."
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="11"
                                                   FontFamily="Segoe UI"
                                                   Margin="12,4,12,8"
                                                   Visibility="{Binding IsAssistantTyping, Converter={StaticResource BoolToVis}}"/>
                                                   
                                        <TextBlock Grid.Row="2"
                                                   Text="✨ Gemini digitando..."
                                                   Foreground="{StaticResource AccentGold}"
                                                   FontSize="11"
                                                   FontFamily="Segoe UI"
                                                   Margin="12,4,12,8"
                                                   Visibility="{Binding IsAiProcessing, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Chat Input Area (Gemini) -->
                                        <Border Grid.Row="3" Background="#11FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0" Padding="12,8">
                                            <StackPanel>
                                                <!-- Image Attachment Preview -->
                                                <Border CornerRadius="8" Background="#33000000" Padding="8" Margin="0,0,0,8" MaxHeight="120" HorizontalAlignment="Left"
                                                        Visibility="{Binding PendingScreenshotBase64, Converter={StaticResource StringToVis}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="60" Height="40" CornerRadius="4" ClipToBounds="True" Margin="0,0,10,0" BorderBrush="#33FFFFFF" BorderThickness="1">
                                                            <Image Source="{Binding PendingScreenshotBase64, Converter={StaticResource Base64ToImg}}" Stretch="UniformToFill"/>
                                                        </Border>
                                                        <TextBlock Text="Print pronto para análise" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" FontSize="11" Margin="0,0,12,0"/>
                                                        <Button Style="{StaticResource BarButton}" Content="✕" Click="ClearScreenshot_Click" ToolTip="Remover anexo" Padding="4"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Input Form -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Style="{StaticResource BarButton}" Content="📸" Click="CaptureScreen_Click" ToolTip="Tirar print da tela" Margin="0,0,8,0" FontSize="14"/>
                                                    <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Text="{Binding AiPrompt, UpdateSourceTrigger=PropertyChanged}" MinWidth="0" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" Margin="0" MinHeight="32" Padding="8,6" Background="#22000000" BorderThickness="1" KeyDown="AiPrompt_KeyDown" AcceptsReturn="False"/>
                                                    <Button Grid.Column="2" Style="{StaticResource BarButton}" Content="➤" Click="SendAiMessage_Click" ToolTip="Enviar para o assistente IA" Margin="8,0,0,0" Foreground="{StaticResource AccentBlue}" IsEnabled="{Binding IsAiProcessing, Converter={StaticResource InvertBoolConverter}}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                </Grid>
                        </Border>
                </Grid>
        </Border>
</Window>
